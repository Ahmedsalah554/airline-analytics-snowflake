def data_quality_check_task(**context):
    """
    Perform basic data quality checks on ingested data.
    Validates row counts and data integrity.
    """
    try:
        pg_hook = PostgresHook(postgres_conn_id=POSTGRES_CONN_ID)
        
        # Check flight offers count
        flight_offers_count = pg_hook.get_first(
            "SELECT COUNT(*) as count FROM raw.flight_offers_raw WHERE ingestion_date = CURRENT_DATE"
        )[0]
        
        # Check airports count
        airports_count = pg_hook.get_first(
            "SELECT COUNT(*) as count FROM raw.airports_raw WHERE ingestion_date = CURRENT_DATE"
        )[0]
        
        # Check airlines count
        airlines_count = pg_hook.get_first(
            "SELECT COUNT(*) as count FROM raw.airlines_raw WHERE ingestion_date = CURRENT_DATE"
        )[0]
        
        logger.info(f"""
            Data Quality Check Results:
            - Flight offers: {flight_offers_count}
            - Airports: {airports_count}
            - Airlines: {airlines_count}
        """)
        
        # Push results for downstream tasks
        context['task_instance'].xcom_push(key='dq_flight_offers', value=flight_offers_count)
        context['task_instance'].xcom_push(key='dq_airports', value=airports_count)
        context['task_instance'].xcom_push(key='dq_airlines', value=airlines_count)
        
        # Basic assertions
        assert flight_offers_count > 0, "No flight offers were ingested"
        assert airports_count > 0, "No airports were ingested"
        assert airlines_count > 0, "No airlines were ingested"
        
        return {
            'flight_offers': flight_offers_count,
            'airports': airports_count,
            'airlines': airlines_count,
            'status': 'PASSED'
        }
    
    except AssertionError as e:
        logger.error(f"Data quality check failed: {e}")
        raise
    except Exception as e:
        logger.error(f"Error in data quality check: {e}")
        raise


