# ========================================
# Configuration
# ========================================

ROUTES = [
    ('NYC', 'LAX'),
    ('JFK', 'LAS'),
    ('LAX', 'ORD'),
    ('MIA', 'BOS'),
    ('SFO', 'JFK'),
    ('ATL', 'DEN'),
]

AIRPORTS = ['JFK', 'LAX', 'ORD', 'DFW', 'DEN', 'SFO', 'LAS', 'MIA', 'BOS', 'ATL']
AIRLINES = ['UA', 'AA', 'DL', 'SW', 'BA', 'LH', 'AF', 'KL']

SNOWFLAKE_CONN_ID = 'snowflake_amadeus'

# ========================================
# Task Functions
# ========================================

def fetch_amadeus_flights(**context):
    """Fetch flight offers from Amadeus API."""
    logger.info("🛫 Starting Amadeus flight data fetch...")
    
    try:
        client = AmadeusAPIClient()
        fetcher = AmadeusDataFetcher(client)
        
        all_flights = []
        
        for origin, destination in ROUTES:
            logger.info(f"📍 Fetching flights: {origin} → {destination}")
            
            flights = fetcher.fetch_flight_offers(
                origin=origin,
                destination=destination,
                departure_date=(datetime.now() + timedelta(days=7)).date(),
                adults=1,
            )
            
            if flights:
                all_flights.extend(flights)
                logger.info(f"✅ Got {len(flights)} flights for {origin}→{destination}")
            else:
                logger.warning(f"⚠️  No flights found for {origin}→{destination}")
        
        # Store in XCom for next task
        context['task_instance'].xcom_push(
            key='flight_data',
            value=json.dumps(all_flights)
        )
        
        logger.info(f"✅ Total flights fetched: {len(all_flights)}")
        return {'status': 'success', 'flights_count': len(all_flights)}
    
    except Exception as e:
        logger.error(f"❌ Error fetching flights: {e}")
        raise


def fetch_amadeus_airports(**context):
    """Fetch airport information from Amadeus API."""
    logger.info("✈️  Starting airport data fetch...")
    
    try:
        client = AmadeusAPIClient()
        fetcher = AmadeusDataFetcher(client)
        
        all_airports = []
        
        for airport_code in AIRPORTS:
            logger.info(f"📍 Fetching airport: {airport_code}")
            
            airport = fetcher.fetch_airport_info(airport_code)
            
            if airport:
                all_airports.append(airport)
                logger.info(f"✅ Got info for {airport_code}")
        
        context['task_instance'].xcom_push(
            key='airport_data',
            value=json.dumps(all_airports)
        )
        
        logger.info(f"✅ Total airports fetched: {len(all_airports)}")
        return {'status': 'success', 'airports_count': len(all_airports)}
    
    except Exception as e:
        logger.error(f"❌ Error fetching airports: {e}")
        raise


