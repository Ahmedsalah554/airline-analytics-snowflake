    )
    
    [fetch_flights, fetch_airports, fetch_airlines]

# Data Loading Tasks
with TaskGroup("load_to_snowflake", tooltip="Load data to Snowflake RAW layer") as load_group:
    load_flights = PythonOperator(
        task_id='load_flights_snowflake',
        python_callable=load_to_snowflake,
        op_kwargs={'data_key': 'flight_data', 'table_name': 'FLIGHT_OFFERS_RAW'},
        provide_context=True,
    )
    
    load_airports = PythonOperator(
        task_id='load_airports_snowflake',
        python_callable=load_to_snowflake,
        op_kwargs={'data_key': 'airport_data', 'table_name': 'AIRPORTS_RAW'},
        provide_context=True,
    )
    
    load_airlines = PythonOperator(
        task_id='load_airlines_snowflake',
        python_callable=load_to_snowflake,
        op_kwargs={'data_key': 'airline_data', 'table_name': 'AIRLINES_RAW'},
        provide_context=True,
    )
    
    [load_flights, load_airports, load_airlines]

# Data Quality Task
data_quality = PythonOperator(
    task_id='data_quality_checks',
    python_callable=validate_data_quality,
    provide_context=True,
)

# dbt Transformation Task
dbt_transform = PythonOperator(
    task_id='dbt_transformations',
    python_callable=trigger_dbt_transformations,
)

# Pipeline Dependencies
ingestion_group >> load_group >> data_quality >> dbt_transform

POSTGRES_CONN_ID = 'postgres_default'


def fetch_flight_offers_task(**context):
    """
    Fetch flight offers for specified routes and insert into raw layer.
    Handles API authentication and data transformation.
    """
    try:
        # Initialize API client
        client = AmadeusAPIClient()
        fetcher = AmadeusDataFetcher(client)
        
        # Departure date is tomorrow from execution date
        exec_date = context['execution_date']
        departure_date = (exec_date + timedelta(days=30)).strftime('%Y-%m-%d')
        
        logger.info(f"Fetching flight offers for departure date: {departure_date}")
        
        # Fetch offers
        records = fetcher.fetch_flight_offers_for_routes(
            routes=ROUTES,
            departure_date=departure_date
        )
        
        # Insert into PostgreSQL raw layer
        pg_hook = PostgresHook(postgres_conn_id=POSTGRES_CONN_ID)
        
        insert_query = """
            INSERT INTO raw.flight_offers_raw 
            (ingestion_date, search_date, origin, destination, raw_payload, api_response_timestamp)
            VALUES (%(ingestion_date)s, %(search_date)s, %(origin)s, %(destination)s, %(raw_payload)s::jsonb, %(api_response_timestamp)s)
        """
        
        for record in records:
            record['raw_payload'] = json.dumps(record['raw_payload'])
            pg_hook.run(insert_query, parameters=record)
        
        logger.info(f"Inserted {len(records)} flight offer records")
        context['task_instance'].xcom_push(key='flight_offers_count', value=len(records))
        
        return len(records)
    
    except Exception as e:
        logger.error(f"Error fetching flight offers: {e}")
        raise


