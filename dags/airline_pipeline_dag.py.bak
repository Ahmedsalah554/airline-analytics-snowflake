def load_to_snowflake(data_key: str, table_name: str, **context):
    """Load data from XCom to Snowflake."""
    logger.info(f"📤 Loading {table_name} to Snowflake...")
    
    try:
        ti = context['task_instance']
        data_json = ti.xcom_pull(key=data_key)
        
        if not data_json:
            logger.warning(f"⚠️  No data found for {table_name}")
            return {'status': 'no_data'}
        
        data = json.loads(data_json)
        
        # Create DataFrame
        df = pd.DataFrame(data if isinstance(data, list) else [data])
        df['LOADED_AT'] = datetime.now()
        
        # Get Snowflake hook
        hook = SnowflakeHook(snowflake_conn_id=SNOWFLAKE_CONN_ID)
        
        # Get engine and write
        with hook.get_sqlalchemy_engine() as engine:
            df.to_sql(
                table_name.lower(),
                engine,
                if_exists='append',
                index=False,
                method='multi',
                chunksize=10000,
            )
        
        logger.info(f"✅ Loaded {len(df)} rows to {table_name}")
        return {'status': 'success', 'rows_loaded': len(df)}
    
    except Exception as e:
        logger.error(f"❌ Error loading to {table_name}: {e}")
        raise


def validate_data_quality(**context):
    """Perform data quality checks."""
    logger.info("🔍 Starting data quality validation...")
    
    try:
        hook = SnowflakeHook(snowflake_conn_id=SNOWFLAKE_CONN_ID)
        
        checks = {
            'FLIGHT_OFFERS_RAW': "SELECT COUNT(*) as cnt FROM RAW.FLIGHT_OFFERS_RAW",
            'AIRPORTS_RAW': "SELECT COUNT(*) as cnt FROM RAW.AIRPORTS_RAW",
            'AIRLINES_RAW': "SELECT COUNT(*) as cnt FROM RAW.AIRLINES_RAW",
        }
        
        results = {}
        for table, query in checks.items():
            result = hook.run(query, autocommit=True)
            logger.info(f"  {table}: {result}")
            results[table] = str(result)
        
        context['task_instance'].xcom_push(
            key='quality_checks',
            value=json.dumps(results)
        )
        
        logger.info("✅ Data quality checks complete")
        return {'status': 'success', 'checks': results}
    
    except Exception as e:
        logger.error(f"❌ Error in data quality checks: {e}")
        raise


def trigger_dbt_transformations():
    """Trigger dbt transformations."""
    logger.info("🔄 Triggering dbt transformations...")
    
    try:
        import subprocess
        
        result = subprocess.run(
            ['dbt', 'run', '--profiles-dir', '/opt/airflow/dbt'],
            capture_output=True,
            text=True,
        )
        
        logger.info(f"dbt output:\n{result.stdout}")
        
        if result.returncode != 0:
            logger.error(f"dbt error:\n{result.stderr}")
            raise Exception(f"dbt run failed: {result.stderr}")
        
        logger.info("✅ dbt transformations completed")
        return {'status': 'success'}
    
    except Exception as e:
        logger.error(f"❌ Error running dbt: {e}")
        raise


# ========================================
# DAG Tasks
# ========================================

# Data Ingestion Tasks
with TaskGroup("data_ingestion", tooltip="Fetch data from Amadeus API") as ingestion_group:
    fetch_flights = PythonOperator(
